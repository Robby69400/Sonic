{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile UV-K5",
      "type": "shell",
      "command": "bash ./compile-with-docker.sh Calypso",
      "problemMatcher": {
        "owner": "cpp",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "filePrefix": "${workspaceFolder}/",
        "pattern": {
          "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error|note):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      }
    }
  ]
}